GEMINI_API_KEY=your_gemini_api_key_here
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin@clara.com
N8N_BASIC_AUTH_PASSWORD=Clara123

N8N_RESTRICT_FILE_ACCESS_TO=/home/node/inputs;/home/node/outputs;/home/node/prompts
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# Asana integration (free tier)
# Store the Personal Access Token in an n8n Asana credential created in the UI.
ASANA_WORKSPACE_GID=your_workspace_gid_here
ASANA_PROJECT_GID=your_project_gid_here