        "jsCode": "const raw = $input.first().json.text;\nconst cleaned = raw.replace(/```json|```/g, '').trim();\nconst agent_spec = JSON.parse(cleaned);\n\nconst account_id = $('Split Out1').first().json.account_id;\n\nagent_spec.account_id = account_id;\nagent_spec.version = 'v1';\nagent_spec.generated_at = new Date().toISOString();\n\nreturn [{ json: { agent_spec, account_id, agent_spec_text: JSON.stringify(agent_spec, null, 2) } }];"
      },
