      "id": "368b572f-4eab-40bb-b159-35bdccb109c1",
      "name": "Extract from File"
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.text;\n\nconst cleaned = raw.replace(/```json|```/g, '').trim();\nconst memo = JSON.parse(cleaned);\n\nconst company = memo.company_name || 'unknown';\nconst account_id = company\n  .toLowerCase()\n  .replace(/[^a-z0-9]/g, '_')\n  .replace(/_+/g, '_');\n\nmemo.account_id = account_id;\nmemo.version = 'v1';\nmemo.created_at = new Date().toISOString();\n\nreturn [{\n  json: {\n    memo_text: JSON.stringify(memo, null, 2),\n    account_id: account_id\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        432,
